# Required
ZEFAME_API_KEY=replace_with_your_zefame_key
DATABASE_URL=postgresql://username:password@host:5432/database
APP_PASSWORD=replace_with_your_app_password
MAX_DEVICES=10

# Docker Compose database credentials
POSTGRES_DB=vboost
POSTGRES_USER=vboost
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_PORT=5433

# Optional
# Set false for local/non-SSL Postgres. Railway usually needs true.
DATABASE_SSL=true

# Comma-separated list of allowed origins. Leave empty to allow all.
ALLOWED_ORIGIN=https://your-app.up.railway.app

# Development-only Vite proxy target
VITE_API_PROXY_TARGET=http://127.0.0.1:3001
